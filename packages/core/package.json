{
  "name": "@neat/core",
  "version": "0.2.0",
  "private": true,
  "description": "NEAT graph engine: tree-sitter extraction, OTel ingest, REST API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "neat": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "compat.json",
    "proto"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.cjs",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@neat/types": "*",
    "chokidar": "^4.0.3",
    "fastify": "^5.0.0",
    "graphology": "^0.25.4",
    "graphology-shortest-path": "^2.1.0",
    "graphology-traversal": "^0.3.1",
    "ignore": "^7.0.0",
    "minimatch": "^10.0.0",
    "protobufjs": "^7.5.6",
    "semver": "^7.6.0",
    "smol-toml": "^1.3.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.21.2",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/semver": "^7.5.8",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  }
}
